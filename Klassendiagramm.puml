@startuml

class User {
  - userId : String
  - name : String
  - email : String
  - adresse : Adresse
  - passwort : String
  + profilErstellen(email : String, passwort : String):boolean
  + profilBearbeiten():boolean
  + profilLöschen():boolean
  + userMelden(userId : String): Report
}

class Helfer {
  - aktuelleTeilnahmen : Hilfsgesuch[]
  - erreichbarkeitsZeitraum : Kalender
  - skills : Skills[]
  + aufGesuchBewerben(gesuchID : String): boolean
  + zeitraumAnpassen():boolean
  + teilnahmeZurückziehen():boolean
}

class Suchender {
  - organisation : String
  - gesuche : Hilfsgesuch[]
  + gesuchErstellen(beschreibung : String, anzahlGesuchteHelfer : int):Hilfsgesuch
  + benachrichtigungVerschicken(nachricht : String):Benachrichtigung
  + helferAnnehmen():boolean
  + helferAblehnen():boolean
}

class Admin {
  - gemeldeteInhalte : Report[]
  - rechte : Rechte[]
  + nutzerSperren(userID : String):boolean
  + nutzerEntsperren(userID : String):boolean
}

class Report {
  - reportId : String
  - reportedUserId : String
  - grund : String
  - details : String
  - erstelltAm : DateTime
}

Report --> User : gemeldeter
Report --> User : meldender

enum Rechte {
  USERERWALTUNG
  ROLLENVERWALTUNG
  INHALTSMODERATION
}

User <|-- Helfer
User <|-- Suchender
User <|-- Admin

class Adresse {
  - land : String
  - stadt : String
  - plz : String
  - strasse : String
  - hausnummer : String
  - longitude : double
  - latitude : double
}

enum Status {
  OFFEN
  IN_BEARBEITUNG
  ERFUELLT
  ABGEBROCHEN
}

abstract class HilfeEintrag {
  - id : String
  - zeitraeume : List<Zeitraum>
  - adresse : Adresse
  - skills : List<Skills>
  + addZeitraum(zeitraum : Zeitraum) : boolean
  + removeZeitraum(zeitraum : Zeitraum): boolean
}

class Hilfsgesuch {
  - beschreibung : String
  - anzahlGesuchteHelfer : int
  - helferListe : List<Helfer>
  - status : Status
  + addHelfer(helfer : Helfer) : boolean
  + getStatus() : Status
  + isFilled() : boolean
}

Suchender "1" -- "*" Hilfsgesuch
HilfeEintrag <|-- Hilfsgesuch

class Hilfsangebot {
  - helfer : Helfer
}

Helfer "1" -- "*" Hilfsangebot
HilfeEintrag <|-- Hilfsangebot

enum Wiederholung {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

class Zeitraum {
  - startZeit : LocalDateTime
  - endZeit : LocalDateTime
  - wiederholung : Wiederholung
  + ueberschneidetSich(mit : Zeitraum) : boolean
}

enum Skills {
  TRAGEN_HEBEN
  AUFRAEUMARBEITEN
  TECHNISCHE_HILFE
  STROMVERSORGUNG
  PUMPEN_BEDIENEN
  MATERIALVERTEILUNG
  TRANSPORT
  ERSTE_HILFE
  SANITAETSDIENST
  BETREUUNG_VON_PERSONEN
  UNTERKUNFTSBETRIEB
  FUNK_KOMMUNIKATION
  KOORDINATION_UNTERSTUETZUNG
}

class Benachrichtigung {
  - id: UUID
  - nachricht: String
  - gelesen: boolean
  + senden()
  + markierenAlsGelesen()
}

class Kalender {
  - zeitraeume : List<Zeitraum>
  + addZeitraum(z : Zeitraum)
  + removeZeitraum(z : Zeitraum)
}

User "1" -- "1" Kalender
User "1" -- "*" Benachrichtigung

class Gui {
  - currentUser: User
  + start()
  + navigateTo(view: View)
}

class ZuordnungsService {
  - angebote : List<Hilfsangebot>
  - gesuche : List<Hilfsgesuch>
  + match(gesuch: Hilfsgesuch) : Hilfsangebot[]
  + match(angebot: Hilfsangebot) : Hilfsgesuch[]
  + weiseHelferZu(gesuch : Hilfsgesuch, angebot: Hilfsangebot) : boolean
  + faehigkeitenMatch(angebot: Hilfsangebot, gesuch: Hilfsgesuch): boolean
  + ortRadiusMatch(angebot: Hilfsangebot, gesuch: Hilfsgesuch, radiusKm: double): boolean
  + zeitMatch(angebot: Hilfsangebot, gesuch: Hilfsgesuch): boolean
  + berechneDistanz(a1: Adresse, a2: Adresse): double
}

Gui -- ZuordnungsService
ZuordnungsService --> Hilfsgesuch
ZuordnungsService --> Hilfsangebot
Gui "1" --> "*" View

@enduml