@startuml

class Benachrichtigung {
  - id: UUID
  - nachricht: String
  - gelesen: boolean
  + senden()
  + markierenAlsGelesen()
}

enum Reapeating {
    DAILY
    WEEKLY
    MONTHLY
    YEARLY
}

class Zeitraum {
    - startZeit: localeDateTime
    - endZeit: localDateTime
    - repeating: Reapeating
    + ueberschneidung(): boolean
}

class Kalender {
    - List<Zeitraum>
}

User "1" -- "*" Benachrichtigung

class Gui {
  - currentUser: User
  - zuordnungsService: ZuordnungsService
  + start()
  + navigateTo(viewName: String)
}

class GesuchListeView {
  + ladeGesuche()
  + filtereGesuche()
  + zeigeDetails(id)
}

class GesuchDetailView {
  - aktuellesGesuch: Hilfsgesuch
  + anzeigen()
  + bewerben()
  + bearbeiten()
}

class AngebotErstellenView {
  + eingabenValidieren()
  + angebotAbsenden()
}

class DashboardView {
  + zeigeMeineGesuche()
  + zeigeMeineAngebote()
}

class BenachrichtigungsView {
  + ladeBenachrichtigungen()
}

class ProfilView {
  + anzeigen()
  + bearbeiten()
}

Gui --> GesuchListeView
Gui --> DashboardView
Gui --> BenachrichtigungsView
Gui --> ProfilView
GesuchListeView --> GesuchDetailView
GesuchDetailView --> AngebotErstellenView

class ZuordnungsService {
  - angebote : List<Hilfsangebot>
  - gesuche : List<Hilfsgesuch>
  + match(gesuch: Hilfsgesuch)
  + match(angebot: Hilfsangebot)
  + weiseHelferZu()
  + faehigkeitenMatch(angebot: Hilfsangebot, gesuch: Hilfsgesuch): boolean
  + ortRadiusMatch(angebot: Hilfsangebot, gesuch: Hilfsgesuch, radiusKm: double): boolean
  + zeitMatch(angebot: Hilfsangebot, gesuch: Hilfsgesuch): boolean
  + berechneDistanz(a1: Adresse, a2: Adresse): double
}

Gui --> ZuordnungsService
ZuordnungsService --> Hilfsgesuch
ZuordnungsService --> Hilfsangebot

@enduml