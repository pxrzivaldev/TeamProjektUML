@startuml

class User {
  - id : String
  - name : String
  - email : String
  - adresse : Adresse
}

class Benutzer {
- skills : Skill[]
+ profilBearbeiten()
+ profilLöschen()
}

class Admin {
- rechte : Rechte[]
+ nutzerBannen(id : String)
}

enum Rechte {
  BENUTZERVERWALTUNG
  ROLLENVERWALTUNG
  INHALTSMODERATION
}

User <|-- Benutzer
User <|-- Admin

class Adresse {
  - land : String
  - stadt : String
  - plz : String
  - strasse : String
  - hausnummer : String
  - longitude : double
  - latitude : double
}

enum Status {
  OFFEN
  IN_BEARBEITUNG
  ERFUELLT
  ABGEBROCHEN
}

class Hilfsgesuch {
  - anzahlGesuchteHelfer : int
  - helferListe : List<Benutzer>
  - adresse: Adresse
  - status : Status
  + addHelfer(helfer : Benutzer) : boolean
  + getStatus() : Status
  + isFilled() : boolean
}

class Hilfsangebot {
  - zeitraeume : List<Zeitraum>
  - user : User
  - skills : List<Skills>
  + addZeitraum(zeitraum : Zeitraum) : boolean
  + removeZeitraum(zeitraum : Zeitraum): boolean
  + getAlleZeitraeume() : List<Zeitraum>
}

enum Wiederholung {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

class Zeitraum {
  - startZeit : LocalDateTime
  - endZeit : LocalDateTime
  - wiederholung : Wiederholung
  + ueberschneidetSich(mit : Zeitraum) : boolean
}

enum Skills {
  informatik
  elektrik
  maschienenbau
  stärke
}

class Benachrichtigung {
  - id: UUID
  - nachricht: String
  - gelesen: boolean
  + senden()
  + markierenAlsGelesen()
}

class Kalender {
  - zeitraeume : List<Zeitraum>
  + addZeitraum(z : Zeitraum)
  + removeZeitraum(z : Zeitraum)
}

User "1" -- "1" Kalender
User "1" -- "*" Benachrichtigung

class Gui {
  - currentUser: User
  + start()
  + navigateTo(view: View)
}

class ZuordnungsService {
  - angebote : List<Hilfsangebot>
  - gesuche : List<Hilfsgesuch>
  + match(gesuch: Hilfsgesuch)
  + match(angebot: Hilfsangebot)
  + weiseHelferZu(gesuch : Hilfsgesuch, angebot: Hilfsangebot) : boolean
  + faehigkeitenMatch(angebot: Hilfsangebot, gesuch: Hilfsgesuch): boolean
  + ortRadiusMatch(angebot: Hilfsangebot, gesuch: Hilfsgesuch, radiusKm: double): boolean
  + zeitMatch(angebot: Hilfsangebot, gesuch: Hilfsgesuch): boolean
  + berechneDistanz(a1: Adresse, a2: Adresse): double
}

Gui -- ZuordnungsService
ZuordnungsService --> Hilfsgesuch
ZuordnungsService --> Hilfsangebot
Gui "1" --> "*" View

@enduml